* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Public Method ZCL_MOT_CVC_REPORT_VIEW->DISPLAY_ROUTES_TO_SELECT
* +-------------------------------------------------------------------------------------------------+
* | [--->] IT_ROUTES                      TYPE        ZTT_ROUTE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD display_routes_to_select.
* Begin ADD:RAVULV1:16-Feb-2021:ECR202002578

  DATA : ls_layout TYPE lvc_s_layo.

  CLEAR : gt_routes_display.

** Build the data for display
  LOOP AT it_routes REFERENCE INTO DATA(lr_route).
    APPEND INITIAL LINE TO gt_routes_display REFERENCE INTO DATA(lr_route_display).
    lr_route_display->route = lr_route->*.
    lr_route_display->radio = icon_wd_radio_button_empty.
  ENDLOOP.

** Build containers to display the data and header information
  build_containers( ).

  IF go_cont_alv IS BOUND AND go_alv_routes IS NOT BOUND.

    go_alv_routes = NEW #( i_parent = go_cont_alv ).

** Build the field catalog for display
    DATA(lt_fieldcat) = build_routes_fieldcatalog( ).

    ls_layout-no_toolbar = abap_true.
    ls_layout-no_rowmark = abap_true.

** Set event handler for handling route selection by the user
    SET HANDLER on_select_route FOR go_alv_routes.

** Set the data for display
    CALL METHOD go_alv_routes->set_table_for_first_display
      EXPORTING
        is_layout                     = ls_layout
      CHANGING
        it_outtab                     = gt_routes_display
        it_fieldcatalog               = lt_fieldcat
      EXCEPTIONS
        invalid_parameter_combination = 1
        program_error                 = 2
        too_many_lines                = 3
        OTHERS                        = 4.
    IF sy-subrc <> 0.
*     Implement suitable error handling here
    ENDIF.

** Build top of page information for user
    build_top_of_page( ).

  ELSE.
    go_alv_routes->refresh_table_display( ).
  ENDIF.

* End ADD:RAVULV1:16-Feb-2021:ECR202002578
ENDMETHOD.


