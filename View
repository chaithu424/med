* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_VIEW->SET_CALC_TYPE
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_CALC_TYPE                   TYPE        ZTV_MOT_CVC_CALC_TYPE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD set_calc_type.

  IF me->g_calc_type IS NOT INITIAL.
    CASE iv_calc_type.
      WHEN zcl_mot_cvc_report_view=>zif_mot_cvc_calc_type~order OR
           zcl_mot_cvc_report_view=>zif_mot_cvc_calc_type~delivery.

        IF me->g_calc_type EQ zcl_mot_cvc_report_view=>zif_mot_cvc_calc_type~sto.
*-        New scenario; "Destroy" alv
          CLEAR me->go_alv.
        ENDIF.
      WHEN zcl_mot_cvc_report_view=>zif_mot_cvc_calc_type~sto.
        IF me->g_calc_type NE zcl_mot_cvc_report_view=>zif_mot_cvc_calc_type~sto.
*-        New scenario; "Destroy" alv
          CLEAR me->go_alv.
        ENDIF.
    ENDCASE.
  ENDIF.

  me->g_calc_type = iv_calc_type.

ENDMETHOD.


