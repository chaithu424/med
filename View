* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_VIEW->BUILD_TOP_OF_PAGE
* +-------------------------------------------------------------------------------------------------+
* | [<-()] RS_LAYOUT                      TYPE        LVC_S_LAYO
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD build_top_of_page.
* Begin ADD:RAVULV1:16-Feb-2021:ECR202002578

  DATA : lv_text TYPE sdydo_text_element.

  DATA(lo_document) = NEW cl_dd_document( ).

* Add header text
  lv_text = 'Shipment Creation'(001).

  lo_document->add_text( text = lv_text
                         sap_fontsize = cl_dd_document=>strong
                         sap_emphasis = cl_dd_document=>strong ).

  lo_document->new_line( ).

* Add message for display
  lv_text = 'Selected deliveries have different routes.'(002) && | | &&
            'Please choose a route to align the deliveries and create shipment'(003) && | | &&
            'or Cancel to abort the process'(004).

  lo_document->add_text( text = lv_text ).

*   Display document
  lo_document->display_document(
    EXPORTING
      parent             = go_cont_top
    EXCEPTIONS
      html_display_error = 1
      OTHERS             = 2 ).

*   Calling the method of ALV to process top of page
  go_alv_routes->list_processing_events(
    EXPORTING
      i_event_name = 'TOP_OF_PAGE'
      i_dyndoc_id  = lo_document ).

* End ADD:RAVULV1:16-Feb-2021:ECR202002578
ENDMETHOD.


