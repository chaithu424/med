* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Static Public Method ZCL_MOT_CVC_REPORT_VIEW=>IS_AUTHORIZED_CUST_OBJ
* +-------------------------------------------------------------------------------------------------+
* | [--->] IT_VKORG                       TYPE        ZTT_R_VKORG
* | [--->] IT_VSTEL                       TYPE        ZTT_R_VSTEL
* | [--->] IT_EKORG                       TYPE        ZTT_R_EKORG
* | [<-()] RV_AUTHORIZED                  TYPE        ABAP_BOOL
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD is_authorized_cust_obj.
*&---------------------------------------------------------------------*
*& Object Id     : RDD1636 / ECR107519                                 *
*& Author        : Jeroen de Zwaan                                     *
*& Creation Date : 12-Feb-2016                                         *
*& Description   : New (standard) Medtronic check added                *
*& Transport No. : DR1K9B37F9                                          *
*&---------------------------------------------------------------------*
*& Object Id     : EDD1636 / ECR107519                                 *
*& Author        : Jeroen de Zwaan (ZWAANJ1)                           *
*& Creation Date : 15-Jun-2016                                         *
*& Description   : STO Amendment                                       *
*& Transport No. : DR1K9B3P32                                          *
*& Change Tag    : -                                                   *
*&---------------------------------------------------------------------*

  CONSTANTS:
    lc_object TYPE xuobject VALUE 'Z_CUST_OBJ',
    lc_vkorg  TYPE xufield  VALUE 'VKORG',
    lc_vstel  TYPE xufield  VALUE 'VSTEL',
    lc_ekorg  TYPE xufield  VALUE 'EKORG'.

  DATA:
    l_vkorg TYPE xuval,
    l_vstel TYPE xuval,
    l_ekorg TYPE xuval.

*-- Check on custom object for sales organization field
  IF lines( it_vkorg ) GT 0.

    SELECT vkorg INTO TABLE @DATA(lt_vkorg) FROM tvko WHERE vkorg IN @it_vkorg.

    IF lines( lt_vkorg ) EQ 0.
      READ TABLE it_vkorg REFERENCE INTO DATA(lr_vkorgssc) INDEX 1.
      MESSAGE e017(zorf_mot_cvc) WITH lr_vkorgssc->low.
    ELSE.
      LOOP AT lt_vkorg REFERENCE INTO DATA(lr_vkorg).
        l_vkorg = lr_vkorg->vkorg.
        CALL FUNCTION 'AUTHORITY_CHECK'
          EXPORTING
            user                = sy-uname
            object              = lc_object
            field1              = lc_vkorg
            value1              = l_vkorg
          EXCEPTIONS
            user_dont_exist     = 1
            user_is_authorized  = 2
            user_not_authorized = 3
            user_is_locked      = 4
            OTHERS              = 5.
        IF sy-subrc EQ 3.
          MESSAGE e018(zorf_mot_cvc) WITH l_vkorg.
        ENDIF.
      ENDLOOP.
    ENDIF.

  ENDIF.

*-- Check on custom object for shipping point field
  IF lines( it_vstel ) GT 0.

    SELECT vstel INTO TABLE @DATA(lt_vstel) FROM tvst WHERE vstel IN @it_vstel.

    IF lines( lt_vstel ) EQ 0.
      READ TABLE it_vstel REFERENCE INTO DATA(lr_vstelssc) INDEX 1.
      MESSAGE e019(zorf_mot_cvc) WITH lr_vstelssc->low.
    ELSE.
      LOOP AT lt_vstel REFERENCE INTO DATA(lr_vstel).
        l_vstel = lr_vstel->vstel.
        CALL FUNCTION 'AUTHORITY_CHECK'
          EXPORTING
            user                = sy-uname
            object              = lc_object
            field1              = lc_vstel
            value1              = l_vstel
          EXCEPTIONS
            user_dont_exist     = 1
            user_is_authorized  = 2
            user_not_authorized = 3
            user_is_locked      = 4
            OTHERS              = 5.
        IF sy-subrc EQ 3.
          MESSAGE e020(zorf_mot_cvc) WITH l_vstel.
        ENDIF.
      ENDLOOP.
    ENDIF.

  ENDIF.

*-- Check on custom object for pruchase organization field
  IF lines( it_ekorg ) GT 0.

    SELECT ekorg INTO TABLE @DATA(lt_ekorg) FROM t024e WHERE ekorg IN @it_ekorg.

    IF lines( lt_ekorg ) EQ 0.
      READ TABLE it_ekorg REFERENCE INTO DATA(lr_ekorgssc) INDEX 1.
      MESSAGE e041(zorf_mot_cvc) WITH lr_ekorgssc->low.
    ELSE.
      LOOP AT lt_ekorg REFERENCE INTO DATA(lr_ekorg).
        l_ekorg = lr_ekorg->ekorg.
        CALL FUNCTION 'AUTHORITY_CHECK'
          EXPORTING
            user                = sy-uname
            object              = lc_object
            field1              = lc_ekorg
            value1              = l_ekorg
          EXCEPTIONS
            user_dont_exist     = 1
            user_is_authorized  = 2
            user_not_authorized = 3
            user_is_locked      = 4
            OTHERS              = 5.
        IF sy-subrc EQ 3.
          MESSAGE e042(zorf_mot_cvc) WITH l_ekorg.
        ENDIF.
      ENDLOOP.
    ENDIF.

  ENDIF.

  rv_authorized = abap_true.

ENDMETHOD.


