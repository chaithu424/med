METHOD build_containers.
* Begin ADD:RAVULV1:16-Feb-2021:ECR202002578

  DATA:
    lo_cust_cont  TYPE REF TO cl_gui_custom_container,   " Container for Custom Controls in the Screen Area
    lo_split_cont TYPE REF TO cl_gui_splitter_container. " Container for Custom Controls in the Screen Area

  IF go_cont_alv IS NOT BOUND.

*   Get the Custom container and Splitter references
    lo_cust_cont  = NEW cl_gui_custom_container( 'GC_CONTAINER' ).
    lo_split_cont = NEW cl_gui_splitter_container( parent = lo_cust_cont  rows = 2  columns = 1 ).

*   Get the Top Of Page, ALV Header & ALV Grid Containers
    go_cont_top = lo_split_cont->get_container( EXPORTING row = 1 column = 1 ).
    go_cont_alv = lo_split_cont->get_container( EXPORTING row = 2 column = 1 ).

*   Set height of ALV Header container
    lo_split_cont->set_row_height(
      EXPORTING
        id                = 1
        height            = 22
      EXCEPTIONS
        cntl_error        = 1
        cntl_system_error = 2
        OTHERS            = 3 ).

  ENDIF.

* End ADD:RAVULV1:16-Feb-2021:ECR202002578
ENDMETHOD.


