METHOD set_alv_layout.
*&---------------------------------------------------------------------*
*& Object Id    : ECR107519                                            *
*& Author       : Jeroen de Zwaan (ZWAANJ1)                            *
*& Creation Date: 12-Nov-2015                                          *
*& Description  : Means of Shipping - consolidation and volume         *
*&                calculation report.                                  *
*& Transport    : DR1K9B37F9                                           *
*&---------------------------------------------------------------------*

  DATA: lw_key    TYPE salv_s_layout_key,
        lo_layout TYPE REF TO cl_salv_layout.

  lo_layout = me->go_alv->get_layout( ).

  IF iv_new EQ abap_true.
    lw_key-report = zcl_mot_cvc_report_view=>gc_report_id-me .
    lo_layout->set_key( lw_key ).

    lo_layout->set_default( abap_true ).

    lo_layout->set_save_restriction( if_salv_c_layout=>restrict_none ).
  ENDIF.

  IF me->g_alv_layout_variant IS NOT INITIAL.
    lo_layout->set_initial_layout( me->g_alv_layout_variant ).
  ENDIF.

ENDMETHOD.


