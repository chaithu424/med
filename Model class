    RETURN.
  ENDIF.

  LOOP AT me->gt_material_numbers REFERENCE INTO DATA(lr_material_number).
    INSERT VALUE ty_objek_nr( objek = CONV objnum( lr_material_number->* )
                              matnr = lr_material_number->* ) INTO TABLE lt_objek.
  ENDLOOP.

  CHECK lt_objek IS NOT INITIAL.

  SELECT objek,
         atzhl,
         adzhl,
         atwrt
    INTO TABLE @DATA(lt_char_value)
    FROM ausp
    FOR ALL ENTRIES IN @lt_objek
    WHERE objek EQ @lt_objek-objek      AND
          mafid EQ @lc_mafid_object     AND
          klart EQ @lc_klart_material   AND
          atinn EQ @l_atinn.
  IF syst-subrc EQ 0.
    SORT lt_char_value BY objek ASCENDING
                          atzhl DESCENDING
                          adzhl DESCENDING.

    DELETE ADJACENT DUPLICATES FROM lt_char_value COMPARING objek.

    LOOP AT lt_char_value REFERENCE INTO DATA(lr_char_value).
      READ TABLE lt_objek REFERENCE INTO DATA(lr_objek) WITH TABLE KEY objek = lr_char_value->objek.
      IF syst-subrc EQ 0.
        INSERT VALUE zcl_mot_cvc_report_model=>ts_cfn_number( matnr = lr_objek->matnr
                                                              cfnnr = lr_char_value->atwrt ) INTO TABLE me->gt_cfn_numbers.
      ENDIF.
    ENDLOOP.
  ENDIF.

ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Protected Method ZCL_MOT_CVC_REPORT_MODEL->SET_MATERIAL_DATA
* +-------------------------------------------------------------------------------------------------+
* | [--->] IT_DATA                        TYPE        ANY TABLE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD set_material_data.

  FIELD-SYMBOLS: <ls_data>  TYPE any,
                 <lv_matnr> TYPE matnr.

  CLEAR me->gt_material_numbers.

  LOOP AT it_data ASSIGNING <ls_data>.
    ASSIGN COMPONENT 'MATNR' OF STRUCTURE <ls_data> TO <lv_matnr>.
    IF syst-subrc EQ 0.
      INSERT <lv_matnr> INTO TABLE me->gt_material_numbers.
    ELSE.
      EXIT.
    ENDIF.
  ENDLOOP.

  CHECK me->gt_material_numbers IS NOT INITIAL.

  SELECT marm~matnr
         mara~meins
         marm~meinh
         marm~umren
         marm~umrez
    INTO TABLE me->gt_material_conversion
    FROM marm
    INNER JOIN mara ON mara~matnr EQ marm~matnr
    FOR ALL ENTRIES IN me->gt_material_numbers
    WHERE marm~matnr EQ me->gt_material_numbers-table_line.


ENDMETHOD.


