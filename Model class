* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Protected Method ZCL_MOT_CVC_REPORT_MODEL->CONVERT_WEIGHT_AND_VOLUME
* +-------------------------------------------------------------------------------------------------+
* | [<-->] CR_MOT_CVC                     TYPE REF TO ZTS_MOT_CVC_REPORT
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD convert_weight_and_volume.
*&---------------------------------------------------------------------*
*& Object Id     : EDD1636 / ECR107519                                 *
*& Author        : Jeroen de Zwaan (ZWAANJ1)                           *
*& Creation Date : 15-Jun-2016                                         *
*& Description   : STO Amendment                                       *
*& Transport No. : DR1K9B3P32                                          *
*&---------------------------------------------------------------------*

  CHECK me->gw_uom IS NOT INITIAL.

  TRY.
      DATA(l_ntgew)     = me->convert_weight( iv_weight = cr_mot_cvc->ntgew
                                              iv_uom    = cr_mot_cvc->gewei ).

      DATA(l_cnf_ntgew) = me->convert_weight( iv_weight = cr_mot_cvc->cnf_ntgew
                                              iv_uom    = cr_mot_cvc->gewei ).

      cr_mot_cvc->ntgew     = l_ntgew.
      cr_mot_cvc->cnf_ntgew = l_cnf_ntgew.
      cr_mot_cvc->gewei     = me->gw_uom-weight.
    CATCH zcx_mot_cvc_report.
*-    Non critical; unconverted values will be used
  ENDTRY.

  TRY.
      DATA(l_volum) = me->convert_volume( iv_volume     = cr_mot_cvc->volum
                                          iv_uom        = cr_mot_cvc->voleh ).

      DATA(l_cnf_volum) = me->convert_volume( iv_volume = cr_mot_cvc->cnf_volum
                                              iv_uom    = cr_mot_cvc->voleh ).


      cr_mot_cvc->volum     = l_volum.
      cr_mot_cvc->cnf_volum = l_cnf_volum.
      cr_mot_cvc->voleh     = me->gw_uom-volume.
    CATCH zcx_mot_cvc_report.
*-    Non critical; unconverted values will be used
  ENDTRY.

ENDMETHOD.


