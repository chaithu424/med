* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_MODEL->CONVERT_QTY_MATERIAL
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_MATERIAL                    TYPE        MATNR
* | [--->] IV_QUANTITY                    TYPE        ZTV_VC_SD_QUANTITY
* | [--->] IV_QUANTITY_UOM                TYPE        MEINS
* | [--->] IV_TARGET_UOM                  TYPE        MEINS
* | [<-()] RV_CONVERTED_QUANTITY          TYPE        ZTV_VC_SD_QUANTITY
* | [!CX!] ZCX_MOT_CVC_REPORT
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD convert_qty_material.
*&---------------------------------------------------------------------*
*& Object Id     : EDD1636 / ECR107519                                 *
*& Author        : Jeroen de Zwaan (ZWAANJ1)                           *
*& Creation Date : 15-Jun-2016                                         *
*& Description   : STO Amendment                                       *
*& Transport No. : DR1K9B3P32                                          *
*&---------------------------------------------------------------------*

  DATA: l_input_flp     TYPE f,
        l_input_flp_alt TYPE f.

  CHECK iv_quantity NE 0.

  READ TABLE me->gt_material_conversion REFERENCE INTO DATA(lr_material_conversion)
  WITH TABLE KEY matnr = iv_material
                 from  = iv_quantity_uom
                 to    = iv_target_uom.
  IF syst-subrc EQ 0.
    IF lr_material_conversion->umren EQ 0 AND lr_material_conversion->umrez EQ 0.
      RAISE EXCEPTION TYPE zcx_mot_cvc_report
        EXPORTING
          textid = zcx_mot_cvc_report=>no_conversion_rule.
    ELSE.
      l_input_flp           = iv_quantity.
      rv_converted_quantity = ( lr_material_conversion->umren / lr_material_conversion->umrez ) * l_input_flp.
    ENDIF.
  ELSE.
*-
    READ TABLE me->gt_material_conversion REFERENCE INTO lr_material_conversion
    WITH TABLE KEY matnr = iv_material
                   from  = iv_target_uom
                   to    = iv_quantity_uom.
    IF syst-subrc EQ 0.
      l_input_flp           = iv_quantity.
      rv_converted_quantity = ( lr_material_conversion->umrez / lr_material_conversion->umren ) * l_input_flp.

      INSERT VALUE zcl_mot_cvc_report_model=>ts_material_conversion( matnr     = iv_material
                                                                     from      = iv_quantity_uom
                                                                     to        = iv_target_uom
                                                                     umren     = lr_material_conversion->umrez
                                                                     umrez     = lr_material_conversion->umren ) INTO TABLE me->gt_material_conversion.
    ELSE.
*-    Try to use other conversion routines
      LOOP AT me->gt_material_conversion REFERENCE INTO lr_material_conversion WHERE matnr EQ iv_material
                                                                                 AND to    EQ iv_target_uom.
*-      Can we convert to the source UoM?
        READ TABLE me->gt_material_conversion REFERENCE INTO DATA(lr_material_conv_alt)
        WITH TABLE KEY matnr = iv_material
                       from  = iv_quantity_uom
                       to    = lr_material_conversion->from.
        IF syst-subrc EQ 0.
          l_input_flp     = iv_quantity.
          l_input_flp_alt = ( lr_material_conv_alt->umren / lr_material_conv_alt->umrez ) * l_input_flp.
        ELSE.
          READ TABLE me->gt_material_conversion REFERENCE INTO lr_material_conv_alt
          WITH TABLE KEY matnr = iv_material
                         from  = lr_material_conversion->from
                         to    = iv_quantity_uom.
          IF syst-subrc EQ 0.
            l_input_flp     = iv_quantity.
            l_input_flp_alt = ( lr_material_conv_alt->umrez / lr_material_conv_alt->umren  ) * l_input_flp.
          ENDIF.
        ENDIF.

        CHECK l_input_flp_alt IS NOT INITIAL.

        rv_converted_quantity = ( lr_material_conversion->umren / lr_material_conversion->umrez ) * l_input_flp_alt.
      ENDLOOP.
    ENDIF.


    IF rv_converted_quantity IS INITIAL.
      INSERT VALUE zcl_mot_cvc_report_model=>ts_material_conversion( matnr     = iv_material
                                                                     from      = iv_quantity_uom
                                                                     to        = iv_target_uom
                                                                     umren     = 0
                                                                     umrez     = 0 ) INTO TABLE me->gt_material_conversion.

      RAISE EXCEPTION TYPE zcx_mot_cvc_report
        EXPORTING
          textid = zcx_mot_cvc_report=>no_conversion_rule.
    ENDIF.
  ENDIF.

ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Protected Method ZCL_MOT_CVC_REPORT_MODEL->CONVERT_TO_PALLETS
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_MATERIAL                    TYPE        MATNR
* | [--->] IV_QUANTITY                    TYPE        ZTV_VC_SD_QUANTITY
* | [--->] IV_QUANTITY_UOM                TYPE        ZTV_VC_SALES_UNIT
* | [--->] IV_VOLUME                      TYPE        ZTV_VC_VOLUME
* | [--->] IV_VOLUME_UOM                  TYPE        VOLEH
* | [<-()] RS_PALLET                      TYPE        ZTS_MOT_CVC_REPORT_CAL
* | [!CX!] ZCX_MOT_CVC_REPORT
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD convert_to_pallets.
*&---------------------------------------------------------------------*
*& Object Id    : ECR107519                                            *
*& Author       : Jeroen de Zwaan (ZWAANJ1)                            *
*& Creation Date: 12-Nov-2015                                          *
*& Description  : Means of Shipping - consolidation and volume         *
*&                calculation report.                                  *
*& Transport    : DR1K9B37F9                                           *
*&---------------------------------------------------------------------*
*& Object Id     : EDD1636 / ECR107519                                 *
*& Author        : Jeroen de Zwaan (ZWAANJ1)                           *
*& Creation Date : 15-Jun-2016                                         *
*& Description   : STO Amendment                                       *
*& Transport No. : DR1K9B3P32                                          *
*&---------------------------------------------------------------------*

  DATA: l_quantity_conv             TYPE ztv_vc_quantity,
        l_quantity_remain           TYPE ztv_vc_quantity,
        l_quantity_remain_sales_uom TYPE ztv_vc_quantity,
        l_volume_remain             TYPE ztv_vc_volume,

        l_palful                    TYPE ztv_vc_palful,
        l_palmix                    TYPE ztv_vc_palmix,
        l_return_code               TYPE syst_subrc.



  TRY.
      l_quantity_conv = me->convert_qty_material( iv_material      = iv_material
                                                  iv_quantity      = iv_quantity
                                                  iv_quantity_uom  = iv_quantity_uom
                                                  iv_target_uom    = me->gw_pallet_type-full_pal_uom ).

*-    Set number of Full pallets
      l_palful = 0.       "++ADD:HINSBJ1:24-Oct-2019:ECR201902195

*-    Calculate the remaining quantity in alternative UoM
      l_quantity_remain = l_quantity_conv - l_palful.

*-   Convert remaining quantity to sales UoM
      TRY.
          l_quantity_remain_sales_uom = me->convert_qty_material( iv_material     = iv_material
                                                                  iv_quantity     = l_quantity_remain
                                                                  iv_quantity_uom = me->gw_pallet_type-full_pal_uom
                                                                  iv_target_uom   = iv_quantity_uom ).
        CATCH zcx_mot_cvc_report.
*-        Quantity conversion failed
          RAISE EXCEPTION TYPE zcx_mot_cvc_report
            EXPORTING
              textid       = zcx_mot_cvc_report=>mat_unit_conversion_failed
              g_uom_source = me->gw_pallet_type-full_pal_uom
              g_uom_target = iv_quantity_uom.
      ENDTRY.

    CATCH zcx_mot_cvc_report.
*-    Conversion rule not found; conversion not possible..
      l_quantity_remain_sales_uom = iv_quantity. " Full quantity = remaining quantity
  ENDTRY.

*- Calculate remaining volume in volume unit
  l_volume_remain = l_quantity_remain_sales_uom * ( iv_volume / iv_quantity ).

*- Calculate "palmix" :  Remaining volume / net volume of the selected pallet type
*-                      ( convert UoM remaining volume to volume UoM Pallet )
  CALL FUNCTION 'UNIT_CONVERSION_SIMPLE'
    EXPORTING
      input                = l_volume_remain
      no_type_check        = ' '
      unit_in              = iv_volume_uom
      unit_out             = me->gw_pallet_type-uom
    IMPORTING
      output               = l_volume_remain
    EXCEPTIONS
      conversion_not_found = 1
      division_by_zero     = 2
      input_invalid        = 3
      output_invalid       = 4
      overflow             = 5
      type_invalid         = 6
      units_missing        = 7
      unit_in_not_found    = 8
      unit_out_not_found   = 9.
  IF syst-subrc EQ 0.
    l_palmix = l_volume_remain / me->gw_pallet_type-vol_net.
  ELSE.
    RAISE EXCEPTION TYPE zcx_mot_cvc_report
      EXPORTING
        textid       = zcx_mot_cvc_report=>volume_conversion_failed
        g_uom_source = iv_volume_uom
        g_uom_target = me->gw_pallet_type-uom.
  ENDIF.

  rs_pallet-palful      = l_palful.
  rs_pallet-palmix      = l_palmix.
  rs_pallet-palmix_uom  = me->gw_pallet_type-uom.

ENDMETHOD.


