* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->CREATE_SHIPMENT
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_TRANS_PLANNING_POINT        TYPE        TPLST
* | [--->] IV_SHIPMENT_TYPE               TYPE        SHTYP
* | [--->] IT_DELIVERIES                  TYPE        ZCL_MOT_CVC_REPORT_CNTRL=>TT_DELIVERIES
* | [<-()] RV_SHIPMENT_NUMBER             TYPE        TKNUM
* | [!CX!] ZCX_MOT_CVC_REPORT
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD create_shipment.

  DATA: l_shipment_number TYPE tknum,
        lw_header_data    TYPE bapishipmentheader,
        lt_item_data      TYPE STANDARD TABLE OF bapishipmentitem,
        lt_return         TYPE bapiret2_tab.


  lw_header_data-trans_plan_pt  = iv_trans_planning_point.
  lw_header_data-shipment_type  = iv_shipment_type.

  LOOP AT it_deliveries REFERENCE INTO DATA(lr_delivery).
    APPEND INITIAL LINE TO lt_item_data REFERENCE INTO DATA(lr_item_data).
    lr_item_data->delivery = lr_delivery->*.
  ENDLOOP.

  CALL FUNCTION 'BAPI_SHIPMENT_CREATE'
    EXPORTING
      headerdata = lw_header_data
    IMPORTING
      transport  = l_shipment_number
    TABLES
      itemdata   = lt_item_data
      return     = lt_return.
  IF syst-subrc EQ 0.
    READ TABLE lt_return TRANSPORTING NO FIELDS WITH KEY type = 'E'.
    IF syst-subrc EQ 0.
      CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.

      RAISE EXCEPTION TYPE zcx_mot_cvc_report
        EXPORTING
          textid = zcx_mot_cvc_report=>shipment_creation_failed.
    ELSE.
      CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'.

      rv_shipment_number = l_shipment_number.
    ENDIF.
  ELSE.
    RAISE EXCEPTION TYPE zcx_mot_cvc_report
      EXPORTING
        textid = zcx_mot_cvc_report=>shipment_creation_failed.
  ENDIF.

ENDMETHOD.


