* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->CHECK_SHIPPING_POINT
* +-------------------------------------------------------------------------------------------------+
* | [--->] IT_GROUP_SHIPPING_POINTS       TYPE        TT_VSTEL(optional)
* | [--->] IV_DELVRY_SHIPPING_POINT       TYPE        VSTEL
* | [--->] IV_GROUP_SHIPPING_POINT        TYPE        VSTEL
* | [<-()] RV_SHIPPING_POINT              TYPE        VSTEL
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD check_shipping_point.
* Begin ADD:RAVULV1:26-Apr-2021:ECR202002578:TPR-23895

  CLEAR rv_shipping_point.

  IF gt_r_shippt_combi_notallowed[] IS INITIAL OR it_group_shipping_points[] IS INITIAL.
    rv_shipping_point = iv_group_shipping_point.
    RETURN.
  ENDIF.

  LOOP AT it_group_shipping_points ASSIGNING FIELD-SYMBOL(<ls_group_shipping_point>).
    READ TABLE gt_r_shippt_combi_notallowed TRANSPORTING NO FIELDS
         WITH KEY vstel1 = <ls_group_shipping_point>
                  vstel2 = iv_delvry_shipping_point BINARY SEARCH.
    IF sy-subrc EQ 0.
      DATA(lv_combination_not_allowed) = abap_true.
      EXIT.
    ENDIF.
  ENDLOOP.

  IF lv_combination_not_allowed IS NOT INITIAL.
    rv_shipping_point = iv_delvry_shipping_point.
  ELSE.
    rv_shipping_point = iv_group_shipping_point.
  ENDIF.

  CLEAR : lv_combination_not_allowed.

* End ADD:RAVULV1:26-Apr-2021:ECR202002578:TPR-23895
ENDMETHOD.


