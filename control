* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->ON_EXEC_CALCULATION_CLICKED
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_SHPMH                       LIKE
* | [--->] IV_SHPMH_NUM                   LIKE
* | [--->] IV_CALC_BASE                   LIKE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD on_exec_calculation_clicked.

  DATA: lw_doc_item  TYPE zcl_mot_cvc_calculator=>ts_doc_item,
        lt_lines     TYPE salv_t_row,
        lt_doc_items TYPE zcl_mot_cvc_calculator=>tt_doc_item,
        lo_exception TYPE REF TO zcx_mot_cvc_report.


  lt_lines  = me->go_view->get_selected_alv_lines( ).

  LOOP AT lt_lines REFERENCE INTO DATA(lr_line).
    READ TABLE me->gt_data REFERENCE INTO DATA(lr_data) INDEX lr_line->*.
    IF syst-subrc EQ 0.
      CASE me->g_calc_type.
        WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~delivery OR
             zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~order.

          lw_doc_item-docnr  = lr_data->vbeln.
          lw_doc_item-posnr  = lr_data->posnr.
        WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~sto.

          lw_doc_item-docnr  = lr_data->ebeln.
          lw_doc_item-posnr  = CONV #( lr_data->ebelp ).
      ENDCASE.

      lw_doc_item-etenr     = lr_data->etenr.

      CASE iv_calc_base.
        WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~confirmed.
          lw_doc_item-volum  = lr_data->cnf_volum.
          lw_doc_item-palful = lr_data->palful_cnf.
          lw_doc_item-palmix = lr_data->palmix_cnf.
        WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~ordered.
          lw_doc_item-volum  = lr_data->volum.
          lw_doc_item-palful = lr_data->palful.
          lw_doc_item-palmix = lr_data->palmix.
      ENDCASE.

      lw_doc_item-voleh  = lr_data->voleh.

*Begin ADD:HINSBJ1:24-Oct-2019:ECR201902195
      TRY.
*Begin ADD:HINSBJ1:22-Jan-2020:DEF20927
          CASE iv_calc_base.
            WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~confirmed.
              lw_doc_item-ntgew = convert_weight( iv_weight = lr_data->cnf_ntgew
                                                  iv_uom    = lr_data->gewei ).

            WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~ordered.
*End ADD:HINSBJ1:22-Jan-2020:DEF20927
              lw_doc_item-ntgew = convert_weight( iv_weight = lr_data->ntgew
                                                  iv_uom    = lr_data->gewei ).
          ENDCASE.    "++ADD:HINSBJ1:22-Jan-2020:DEF20927

        CATCH zcx_mot_cvc_report.
*Begin ADD:HINSBJ1:22-Jan-2020:DEF20927
          CASE iv_calc_base.
            WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~confirmed.
              lw_doc_item-ntgew = lr_data->cnf_ntgew.
            WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_base~ordered.
*End ADD:HINSBJ1:22-Jan-2020:DEF20927
              lw_doc_item-ntgew = lr_data->ntgew.
          ENDCASE.    "++ADD:HINSBJ1:22-Jan-2020:DEF20927
      ENDTRY.
*End ADD:HINSBJ1:24-Oct-2019:ECR201902195

      INSERT lw_doc_item INTO TABLE lt_doc_items.
    ENDIF.
  ENDLOOP.

  TRY.
      me->go_view->set_calculation_results( is_result = zcl_mot_cvc_calculator=>calculate_volume(
                                                                                     EXPORTING
