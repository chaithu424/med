                        dgrel = lr_delivery_data->zzdg_trans
                        gt_profl = lt_profl
                        gt_vstel = VALUE #( ( lr_delivery_data->vstel ) )  " ++ADD:RAVULV1:26-Apr-2021:ECR202002578:TPR-23895
                        deliveries = VALUE #( ( vbeln = lr_item_reg->vbeln
                                                route = lr_delivery_data->route
