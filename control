* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->ON_START_OF_SELECTION
* +-------------------------------------------------------------------------------------------------+
* | [--->] IS_CRITERIA                    LIKE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD on_start_of_selection.


  DATA: lw_type      TYPE zts_mot_cvc_sel_type,

        lo_model_va  TYPE REF TO zcl_mot_cvc_report_mdl_va,
        lo_model_vl  TYPE REF TO zcl_mot_cvc_report_mdl_vl,
        lo_exception TYPE REF TO zcx_mot_cvc_report.


  MOVE-CORRESPONDING is_criteria TO lw_type.

  CASE lw_type-calc_type.
    WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~order.
      me->go_model ?= zcl_mot_cvc_report_mdl_va=>factory( ).
    WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~delivery.
      me->go_model ?= zcl_mot_cvc_report_mdl_vl=>factory( ).
    WHEN zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~sto.
      me->go_model ?= zcl_mot_cvc_report_mdl_st=>factory( ).
  ENDCASE.

  IF me->go_model IS BOUND.
    TRY.
        me->g_calc_type = lw_type-calc_type.

        me->gt_data = me->go_model->get_data( is_selection_criteria = is_criteria ).

        me->set_last_selection( is_criteria = is_criteria ).

        me->go_view->display_overview( iv_calc_type = me->g_calc_type ).

      CATCH zcx_mot_cvc_report INTO lo_exception.
        MESSAGE lo_exception TYPE 'I' DISPLAY LIKE 'W'.

        me->go_view->return_to_selection_screen( ).
    ENDTRY.
  ENDIF.

ENDMETHOD.


