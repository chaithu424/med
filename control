* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->ON_EXEC_CREATE_SHIP_CLICKED
* +-------------------------------------------------------------------------------------------------+
* | [--->] IV_TRANS_PLANNING_POINT        LIKE
* | [--->] IV_SHIPMENT_TYPE               LIKE
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD on_exec_create_ship_clicked.

  DATA: l_shipment_number TYPE tknum,
        lo_exception      TYPE REF TO zcx_mot_cvc_report,
        lt_lines          TYPE salv_t_row,
        lt_deliveries     TYPE zcl_mot_cvc_report_cntrl=>tt_deliveries.


  CHECK me->g_calc_type EQ zcl_mot_cvc_report_cntrl=>zif_mot_cvc_calc_type~delivery.

  lt_lines = me->go_view->get_selected_alv_lines( ).

  LOOP AT lt_lines REFERENCE INTO DATA(lr_line).
    READ TABLE me->gt_data REFERENCE INTO DATA(lr_data) INDEX lr_line->*.
    IF syst-subrc EQ 0.
      INSERT lr_data->vbeln INTO TABLE lt_deliveries. " Unique entries only
    ENDIF.
  ENDLOOP.

  CHECK lt_deliveries IS NOT INITIAL.

  TRY.
      l_shipment_number = me->create_shipment(
                                 iv_trans_planning_point = iv_trans_planning_point
                                 iv_shipment_type        = iv_shipment_type
                                 it_deliveries           = lt_deliveries
                                    ).

      MESSAGE i012 DISPLAY LIKE 'S' WITH l_shipment_number.

      me->refresh_overview( ).

    CATCH zcx_mot_cvc_report INTO lo_exception.
      MESSAGE lo_exception TYPE 'I' DISPLAY LIKE 'W'.
  ENDTRY.


ENDMETHOD.


