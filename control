ENDMETHOD.


* <SIGNATURE>---------------------------------------------------------------------------------------+
* | Instance Private Method ZCL_MOT_CVC_REPORT_CNTRL->SET_LAST_SELECTION
* +-------------------------------------------------------------------------------------------------+
* | [--->] IS_CRITERIA                    TYPE        ANY
* +--------------------------------------------------------------------------------------</SIGNATURE>
METHOD set_last_selection.

  FIELD-SYMBOLS <ls_criteria> TYPE any.

  DATA(lo_typedescr) = cl_abap_typedescr=>describe_by_data( is_criteria ).

  IF lo_typedescr IS BOUND.

    CHECK lo_typedescr->is_ddic_type( ).

    DATA(lw_ddic_header) = lo_typedescr->get_ddic_header( ).

    CREATE DATA me->gr_last_selection TYPE (lw_ddic_header-tabname).

    ASSIGN me->gr_last_selection->* TO <ls_criteria>.

    <ls_criteria> = is_criteria.
  ENDIF.

ENDMETHOD.


