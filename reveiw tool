*&      Form  SUB_RFC_CHECK
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
  FORM sub_rfc_check  USING uv_rfcdest TYPE rfcdest   " Logical destination (specified in function call)
                      CHANGING cv_subrc TYPE sysubrc. " Return Code

    CALL FUNCTION 'RFC_PING' DESTINATION uv_rfcdest
      EXCEPTIONS
        system_failure        = 1
        communication_failure = 2
        OTHERS                = 3.
    IF sy-subrc = 0.
      cv_subrc = sy-subrc.
    ENDIF. " IF sy-subrc = 0
  ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SUB_PENDING_REVIEW
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*  -->  p1        text
*  <--  p2        text
*----------------------------------------------------------------------*
  FORM sub_pending_review .

    TYPES: BEGIN OF lts_alv,
             ecr_no        TYPE z_ecrno,    " ECR Number (GPS)
             developer_id  TYPE syst_uname, " ABAP System Field: Name of Current User
             reviewer_name TYPE char40,     " Name of type CHAR40
             erdat         TYPE erdat,      " Date on Which Record Was Created
*             eta           TYPE datum,
             aging         TYPE i,      " Aging of type Integers
             status        TYPE char25, " Status of type CHAR25
           END OF lts_alv.
    DATA: lt_fieldcat TYPE slis_t_fieldcat_alv,
          ls_fieldcat TYPE slis_fieldcat_alv,
          gs_selfield TYPE slis_selfield,
          lt_alv_data TYPE STANDARD TABLE OF lts_alv,
          lt_tab_a    TYPE STANDARD TABLE OF dd07v, " Generated Table for View
          lt_tab_b    TYPE STANDARD TABLE OF dd07v. " Generated Table for View

    CONSTANTS:lc_stat_01 TYPE z_review_stat VALUE '1', " Review Status
              lc_stat_02 TYPE z_review_stat VALUE '2'. " Review Status

    CASE sscrfields-ucomm.
      WHEN 'FC02'.
        ls_fieldcat-fieldname  = 'ECR_NO'.
        ls_fieldcat-seltext_m  = 'Ecr Number'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

        ls_fieldcat-fieldname  = 'DEVELOPER_ID'.
        ls_fieldcat-seltext_m  = 'Developer'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

        ls_fieldcat-fieldname  = 'REVIEWER_NAME'.
        ls_fieldcat-seltext_m  = 'Reviewer Name'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

        ls_fieldcat-fieldname  = 'ERDAT'.
        ls_fieldcat-seltext_m  = 'Record Created Date'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

*        ls_fieldcat-fieldname  = 'ETA'.
*        ls_fieldcat-seltext_m  = 'ETA'.
*        APPEND ls_fieldcat TO lt_fieldcat.
*        CLEAR:ls_fieldcat.

        ls_fieldcat-fieldname  = 'AGING'.
        ls_fieldcat-seltext_m  = 'Aging in days'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

        ls_fieldcat-fieldname  = 'STATUS'.
        ls_fieldcat-seltext_m  = 'Status'.
        APPEND ls_fieldcat TO lt_fieldcat.
        CLEAR:ls_fieldcat.

        CALL FUNCTION 'DD_DOMA_GET'
          EXPORTING
            domain_name   = 'Z_REVIEW_STAT'
*           GET_STATE     = 'M  '
            langu         = sy-langu
*           PRID          = 0
*           WITHTEXT      = 'X'
          TABLES
            dd07v_tab_a   = lt_tab_a
            dd07v_tab_n   = lt_tab_b
          EXCEPTIONS
            illegal_value = 1
            op_failure    = 2
            OTHERS        = 3.
        IF sy-subrc = 0.
          SORT lt_tab_a BY domvalue_l.
        ENDIF. " IF sy-subrc = 0


        SELECT ecr_no,developer_id,reviewer_name,status,erdat,eta
          FROM zcap_review_hd " Header table for review process tracking
          INTO TABLE @DATA(lt_rev_det)
          WHERE status IN ( @lc_stat_01, @lc_stat_02 ).
        IF sy-subrc = 0.
          LOOP AT lt_rev_det ASSIGNING FIELD-SYMBOL(<ls_rev>).
            APPEND INITIAL LINE TO lt_alv_data ASSIGNING FIELD-SYMBOL(<ls_alv_data>).
            IF <ls_alv_data> IS ASSIGNED.
              <ls_alv_data>-ecr_no = <ls_rev>-ecr_no.
              <ls_alv_data>-developer_id = <ls_rev>-developer_id.
              <ls_alv_data>-reviewer_name = <ls_rev>-reviewer_name.
              <ls_alv_data>-erdat = <ls_rev>-erdat.
              <ls_alv_data>-aging = sy-datum - <ls_rev>-erdat.
              READ TABLE lt_tab_a ASSIGNING FIELD-SYMBOL(<ls_tab>) WITH KEY domvalue_l = <ls_rev>-status
                                                                            BINARY SEARCH.
              IF sy-subrc = 0 AND <ls_tab> IS ASSIGNED.
                <ls_alv_data>-status = <ls_tab>-ddtext.
              ENDIF. " IF sy-subrc = 0 AND <ls_tab> IS ASSIGNED
            ENDIF. " IF <ls_alv_data> IS ASSIGNED
          ENDLOOP. " LOOP AT lt_rev_det ASSIGNING FIELD-SYMBOL(<ls_rev>)

          CALL FUNCTION 'REUSE_ALV_POPUP_TO_SELECT'
            EXPORTING
              i_title       = 'Pending Reviews'
              i_tabname     = '1'
              it_fieldcat   = lt_fieldcat
            IMPORTING
              es_selfield   = gs_selfield
            TABLES
              t_outtab      = lt_alv_data
            EXCEPTIONS
              program_error = 1
              OTHERS        = 2.
          IF sy-subrc = 0.
            READ TABLE lt_alv_data INDEX gs_selfield-tabindex INTO DATA(ls_alv_data).
            MOVE ls_alv_data-ecr_no TO p_ecr_no.
          ENDIF. " IF sy-subrc = 0
        ENDIF. " IF sy-subrc = 0

      WHEN OTHERS.
    ENDCASE.

  ENDFORM.
*  ENDFORM.
*&---------------------------------------------------------------------*
*&      Form  SUB_GET_SCI_DETAILS
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_LT_TR  text
*      <--P_LT_LIST  text
*----------------------------------------------------------------------*
  FORM sub_get_sci_details  USING    ut_tr TYPE tt_tr
                            CHANGING ct_list TYPE scit_alvlistn.
    DATA: lt_result   TYPE scit_rest,
          lt_list_tmp TYPE scit_alvlistn,
          lv_val      TYPE c LENGTH 32, " Val of type Character
          lv_variant  TYPE sci_chkv,    " Code Inspector: Element Name of a Check Variant
          lv_gui_on   TYPE c,           " Gui_on of type Character
          lv_subrc    TYPE sysubrc,     " Return Code
          lv_rfcdest  TYPE rfcdest.     " Logical destination (specified in function call)

* Get the Variant name
    cl_satc_ac_config_access=>load_value(
         EXPORTING
           i_key = if_satc_ac_config_state_names=>c_config-ci_check_variant "CI.CHECK.VARIANT
         IMPORTING
           e_value = lv_val ).
    lv_variant = lv_val .
* Get the SCI details
    LOOP AT ut_tr ASSIGNING FIELD-SYMBOL(<ls_tr>).
      CONDENSE <ls_tr>.
      CASE <ls_tr>-trkorr+0(2).
        WHEN 'DR'.
          CALL FUNCTION 'ZSC_TEST_RUN_SCI'
            EXPORTING
              iv_variant    = lv_variant
              iv_tr         = <ls_tr>-trkorr
            IMPORTING
              et_result     = lt_result
              et_plain_list = lt_list_tmp.
          IF sy-subrc = 0.
            DELETE lt_list_tmp WHERE kind EQ '3_N'.
            APPEND LINES OF lt_list_tmp TO ct_list.
          ENDIF . " IF sy-subrc = 0
        WHEN 'DC'.
          lv_rfcdest = gc_rfcdest_dc.
          PERFORM sub_rfc_check  USING lv_rfcdest
                                 CHANGING lv_subrc.

          IF lv_subrc = 0.

*            CALL FUNCTION 'ZDC_TEST_RUN_SCI' DESTINATION lv_rfcdest
*              EXPORTING
*                iv_variant    = lv_variant
*                iv_tr         = <ls_tr>-trkorr
*              IMPORTING
*                et_result     = lt_result
*                et_plain_list = lt_list_tmp.
*            IF sy-subrc = 0.
*              DELETE lt_list_tmp WHERE kind EQ '3_N'.
*              APPEND LINES OF lt_list_tmp TO ct_list.
*            ENDIF.
          ENDIF. " IF lv_subrc = 0
        WHEN 'DG'.

          lv_rfcdest = gc_rfcdest_dg.
          PERFORM sub_rfc_check USING lv_rfcdest
                                CHANGING lv_subrc.
          IF lv_subrc = 0.

            CALL FUNCTION 'ZGTS_TEST_RUN_SCI' DESTINATION lv_rfcdest
              EXPORTING
                iv_variant    = lv_variant
                iv_tr         = <ls_tr>-trkorr
              IMPORTING
                et_result     = lt_result
                et_plain_list = lt_list_tmp.
            IF sy-subrc = 0.
              DELETE lt_list_tmp WHERE kind EQ '3_N'.
              APPEND LINES OF lt_list_tmp TO ct_list.
            ENDIF. " IF sy-subrc = 0
          ENDIF. " IF lv_subrc = 0
        WHEN 'DA'.

          lv_rfcdest = gc_rfcdest_da.
          PERFORM sub_rfc_check USING lv_rfcdest
                                CHANGING lv_subrc.
          IF lv_subrc = 0.

            CALL FUNCTION 'ZDA_TEST_RUN_SCI' DESTINATION lv_rfcdest
              EXPORTING
                iv_variant    = lv_variant
                iv_tr         = <ls_tr>-trkorr
              IMPORTING
                et_result     = lt_result
                et_plain_list = lt_list_tmp.
            IF sy-subrc = 0.
              DELETE lt_list_tmp WHERE kind EQ '3_N'.
              APPEND LINES OF lt_list_tmp TO ct_list.
            ENDIF. " IF sy-subrc = 0
          ENDIF. " IF lv_subrc = 0
        WHEN OTHERS.
      ENDCASE.
    ENDLOOP. " LOOP AT ut_tr ASSIGNING FIELD-SYMBOL(<ls_tr>)


  ENDFORM.


