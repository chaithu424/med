      <l_points_tab>-issue_desc     = <l_review_it>-issue_desc     .
      READ TABLE t_taba_def_catg ASSIGNING FIELD-SYMBOL(<l_taba>)
                                 WITH KEY domvalue_l = <l_review_it>-defect_cat.
      IF sy-subrc = 0.
        CONCATENATE <l_taba>-domvalue_l
                  '-'
                  <l_taba>-ddtext
             INTO <l_points_tab>-defect_cat
             SEPARATED BY space.
      ENDIF. " IF sy-subrc = 0

*Pick Sub category based on Defect Category selected
      READ TABLE t_defect_subcat ASSIGNING FIELD-SYMBOL(<lwa_subcat>)
                                          WITH KEY defect_subcat = <l_review_it>-defect_subcat.
      IF sy-subrc = 0.
        CONCATENATE <lwa_subcat>-defect_subcat '-' <lwa_subcat>-defect_subcatt INTO <l_points_tab>-defect_subcat SEPARATED BY space.
      ENDIF. " IF sy-subrc = 0

      READ TABLE t_taba_prio ASSIGNING <l_taba>
                           WITH KEY domvalue_l = <l_review_it>-priority.
      IF sy-subrc = 0.
        CONCATENATE <l_taba>-domvalue_l
                  '-'
                  <l_taba>-ddtext
             INTO <l_points_tab>-priority
             SEPARATED BY space.
      ENDIF. " IF sy-subrc = 0

      <l_points_tab>-last_rev_date  = <l_review_it>-last_rev_date  .
      <l_points_tab>-reviewer_comm  = <l_review_it>-reviewer_comm  .
      <l_points_tab>-developer_comm = <l_review_it>-developer_comm .

      READ TABLE t_taba_def_stat ASSIGNING <l_taba>
                           WITH KEY domvalue_l = <l_review_it>-status.
