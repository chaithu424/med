        CONCATENATE <l_taba>-domvalue_l
                  '-'
                  <l_taba>-ddtext
             INTO <l_points_tab>-status
             SEPARATED BY space.
      ENDIF. " IF sy-subrc = 0

    ENDLOOP. " LOOP AT t_review_it_act ASSIGNING FIELD-SYMBOL(<l_review_it>)

