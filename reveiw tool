           lt_e071        TYPE STANDARD TABLE OF ty_e071.                    " Change & Transport System: Object Entries of Requests/Tasks

    DATA:l_rfc_dest TYPE rfcdes-rfcdest, " Logical destination (specified in function call)
         l_text     TYPE string,
         l_len      TYPE i,              " Len of type Integers
         l_tabname  TYPE tabname.        " Table Name

    CONSTANTS:lc_percent TYPE char1 VALUE '%', " Percent of type CHAR1
              lc_bracket TYPE char1 VALUE ')'. " Bracket of type CHAR1

    CLEAR: t_data.
    DATA:ls_data1 TYPE tab512 . " Table with a 512 byte field

    LOOP AT  s_tr INTO DATA(ls_trans)
*       WHERE low+0(2) = p_target+0(2). " --DEL:MAZUMS4:16-Feb-2023
      WHERE low+0(2) = p_target+5(2). " ++ADD:MAZUMS4:16-Feb-2023
      ls_data1-wa = ls_trans-low.
      APPEND ls_data1 TO t_data.
      CLEAR:ls_data1,ls_trans.
    ENDLOOP. " LOOP AT s_tr INTO DATA(ls_trans)

    PERFORM sub_get_rfc_input.
 "required fields
    CLEAR: t_fields.
    ls_fields-fieldname = c_trkorr.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields .
 "required fields
    ls_fields-fieldname = c_trfunction.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields,t_data.

    l_tabname = c_e070.
    PERFORM sub_get_table_data USING p_target
                                     l_tabname.

    LOOP AT t_data INTO DATA(ls_data).
      CONDENSE ls_data-wa.
      SPLIT ls_data-wa AT space INTO: DATA(l_trkorr)  DATA(l_trfunc).

      CASE  l_trfunc.
        WHEN 'K'.
          ls_tr-trkorr = l_trkorr.
          ls_tr-trfunction = l_trfunc .
          APPEND ls_tr TO lt_tr.
          CLEAR:ls_tr.

        WHEN 'W'.
          ls_tr-trkorr = l_trkorr.
          ls_tr-trfunction = l_trfunc .
          APPEND ls_tr TO lt_tr.
          CLEAR:ls_tr.
        WHEN OTHERS.
      ENDCASE.

    ENDLOOP. " LOOP AT t_data INTO DATA(ls_data)

    APPEND LINES OF lt_tr TO t_tr.

    PERFORM sub_get_rfc_input1.
 "required fields
    CLEAR: t_fields.
    ls_fields-fieldname = c_trkorr.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields .
 "required fields
    ls_fields-fieldname = c_trfunction.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields,t_data.

    l_tabname = c_e070.
    PERFORM sub_get_table_data USING p_target
                                     l_tabname.

    LOOP AT t_data INTO ls_data.
      CONDENSE ls_data-wa.
      SPLIT ls_data-wa AT space INTO: l_trkorr l_trfunc.

      CASE  l_trfunc.
        WHEN 'K'.
          ls_tr-trkorr = l_trkorr.
          ls_tr-trfunction = l_trfunc .
          APPEND ls_tr TO lt_tr.
          CLEAR:ls_tr.

        WHEN 'W'.
          ls_tr-trkorr = l_trkorr.
          ls_tr-trfunction = l_trfunc .
          APPEND ls_tr TO lt_tr.
          CLEAR:ls_tr.
        WHEN OTHERS.
          ls_tr-trkorr = l_trkorr.
          ls_tr-trfunction = l_trfunc .
          APPEND ls_tr TO lt_tr.
          CLEAR:ls_tr.
      ENDCASE.

    ENDLOOP. " LOOP AT t_data INTO ls_data

    APPEND LINES OF lt_tr TO t_tr.
    SORT t_tr BY trkorr.
    DELETE ADJACENT DUPLICATES FROM t_tr COMPARING trkorr.

    LOOP AT  t_tr INTO DATA(ls_trans1).
      ls_data1-wa = ls_trans1-trkorr.
      APPEND ls_data1 TO t_data.
      CLEAR:ls_data1,ls_trans1.
    ENDLOOP. " LOOP AT t_tr INTO DATA(ls_trans1)

    PERFORM sub_get_rfc_input.

 "required fields
    CLEAR: t_fields.
    ls_fields-fieldname = c_trkorr.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields.
 "required fields
    ls_fields-fieldname = c_pgmid.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields .

 "required fields
    ls_fields-fieldname = c_object.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields .
 "required fields
    ls_fields-fieldname = c_obj_name.
    APPEND ls_fields TO t_fields.
    CLEAR:ls_fields, t_data.

    l_tabname = c_e071.
    PERFORM sub_get_table_data USING p_target
                                     l_tabname.

    LOOP AT t_fields ASSIGNING FIELD-SYMBOL(<fs_fields>).
      CASE <fs_fields>-fieldname.
        WHEN c_trkorr.
          DATA(l_offset_tr) = <fs_fields>-offset.
          DATA(l_len_tr) = <fs_fields>-length.
        WHEN c_pgmid.
          DATA(l_offset_pg) = <fs_fields>-offset.
          DATA(l_len_pg) = <fs_fields>-length.
        WHEN c_object.
          DATA(l_offset_obj) = <fs_fields>-offset.
          DATA(l_len_obj) = <fs_fields>-length.
        WHEN c_obj_name.
          DATA(l_offset_objnm) = <fs_fields>-offset.
          DATA(l_len_objnm) = <fs_fields>-length.
        WHEN OTHERS.
      ENDCASE.

    ENDLOOP. " LOOP AT t_fields ASSIGNING FIELD-SYMBOL(<fs_fields>)

    LOOP AT t_data INTO ls_data.
      ls_e071-trkorr = ls_data-wa+l_offset_tr(l_len_tr).
      ls_e071-pgmid = ls_data-wa+l_offset_pg(l_len_pg).
      ls_e071-object = ls_data-wa+l_offset_obj(l_len_obj).
      ls_e071-obj_name = ls_data-wa+l_offset_objnm(l_len_objnm).
      APPEND ls_e071 TO lt_e071.
      CLEAR:ls_data.
    ENDLOOP. " LOOP AT t_data INTO ls_data

    APPEND LINES OF lt_e071 TO t_e071_rfc.

    DATA: ls_e070_a TYPE ty_e070. " Transport system: Headers of requests/tasks
    LOOP AT t_tr[] INTO DATA(ls_tr_a).
      ls_e070_a-trkorr = ls_tr_a-trkorr.
      ls_e070_a-trfunction = ls_tr_a-trfunction.
      APPEND ls_e070_a TO t_e070[].
      CLEAR: ls_tr_a, ls_e070_a.
    ENDLOOP. " LOOP AT t_tr[] INTO DATA(ls_tr_a)

  ENDFORM.
