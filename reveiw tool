      IF sy-subrc = 0.
        gv_flag = abap_true.
        READ TABLE lt_msg INDEX gs_selfield-tabindex INTO ls_msg.
        IF sy-subrc = 0 AND ( ls_msg-error NE 0 OR ls_msg-warning NE 0 ).
          IF t_points_tab[] IS INITIAL.
            APPEND INITIAL LINE TO t_points_tab ASSIGNING FIELD-SYMBOL(<ls_point_tab>).
            IF <ls_point_tab> IS ASSIGNED.
              <ls_point_tab>-issue_no = lc_1.
              <ls_point_tab>-obj_name = ls_msg-objname.
              <ls_point_tab>-obj_type = ls_msg-objtype.
              <ls_point_tab>-defect_cat = 'CS - Coding Standards not followed'.
              <ls_point_tab>-defect_subcat = 'SCI/CVA Point'.
              <ls_point_tab>-issue_desc = 'CVA / SCI error exist'.
              <ls_point_tab>-priority =   '1 - High'.
              <ls_point_tab>-last_rev_date = sy-datum.
              <ls_point_tab>-reviewer_comm  = 'Please remove the CVA/SCI error'.

            ENDIF. " IF <ls_point_tab> IS ASSIGNED
          ENDIF. " IF t_points_tab[] IS INITIAL

        ENDIF. " IF sy-subrc = 0 AND ( ls_msg-error NE 0 OR ls_msg-warning NE 0 )
      ENDIF. " IF sy-subrc = 0
    ELSE. " ELSE -> IF <ls_point_tab> IS ASSIGNED
      gv_flag = abap_true.
      MESSAGE i999(zf) WITH 'List Contains no data' INTO DATA(lt_data).
    ENDIF. " IF lt_msg IS NOT INITIAL

  ENDFORM.
