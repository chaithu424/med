*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
*      -->P_W_REVIEW_HD_ACT_LAST_REV_DATE  text
*      <--P_P_W_HEADER_VALUE_LAST_REVIEW_D  text
*----------------------------------------------------------------------*
  FORM sub_date_formatted  USING    p_date TYPE datum " Date
  CHANGING p_date_formatted TYPE cacl_string.         " String

    CONSTANTS:
    lc_hiphen TYPE char1 VALUE '-'. " Hiphen of type CHAR1

* Local data declaration
    DATA:
      l_day      TYPE numc2, " Two digit number
      l_month_no TYPE numc2, " Two digit number
      l_year     TYPE numc4, " Count parameters
      l_month    TYPE fcktx. " Month short text

    IF p_date IS NOT INITIAL.

*   Date format will be always YYYYMMDD for input to this subroutine
      l_day = p_date+6(2).
      l_month_no = p_date+4(2).
      l_year = p_date+0(4).

*   Return the month name
      CALL FUNCTION 'ISP_GET_MONTH_NAME'
        EXPORTING
          language     = sy-langu
          month_number = l_month_no
        IMPORTING
          shorttext    = l_month
        EXCEPTIONS
          calendar_id  = 1
          date_error   = 2
          not_found    = 3
          wrong_input  = 4
          OTHERS       = 5.

      IF sy-subrc = 0.
*     Convert date to DDMMMYYYY format
        CONCATENATE l_day
        l_month
        l_year
        INTO p_date_formatted
        SEPARATED BY lc_hiphen.
      ELSE. " ELSE -> IF sy-subrc = 0
        CONCATENATE l_day
        l_month_no
        l_year
        INTO p_date_formatted
        SEPARATED BY lc_hiphen.
      ENDIF. " IF sy-subrc = 0
    ENDIF. " IF p_date IS NOT INITIAL


  ENDFORM.
