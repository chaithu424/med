  FORM sub_display_alv .

    CASE g_role_indc.
      WHEN c_role_a. " Admin
        IF w_review_hd_act-status = '1'.
          CALL SCREEN 9002.
        ELSE. " ELSE -> IF w_review_hd_act-status = '1'
          CALL SCREEN 9001.
        ENDIF. " IF w_review_hd_act-status = '1'

      WHEN c_role_d. " Developer
        CALL SCREEN 9001.
      WHEN c_role_r. " Reviewer
        CALL SCREEN 9001.
      WHEN c_role_o. " Others
        PERFORM sub_lock_unlock USING abap_false
                                    w_review_hd_act
                          CHANGING t_review_lock_data.
        CALL SCREEN 9001.
      WHEN OTHERS.
        MESSAGE s999 WITH 'Sorry! Your are not authorized to ' 'this specific task' DISPLAY LIKE 'E'.
    ENDCASE.

  ENDFORM.
