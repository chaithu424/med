  FORM sub_get_remote_transport USING p_target TYPE rfcdest. " Logical destination (specified in function call)

    DATA: lt_tr TYPE STANDARD TABLE OF ty_tr,
          ls_tr TYPE ty_tr.
    DATA : lt_t_options   TYPE TABLE OF rfc_db_opt,                          " RFC Table Read: Select Options / WHERE Clause
           lt_source_code TYPE STANDARD TABLE OF abaptxt255  INITIAL SIZE 0, " ABAP Text Line with Length 255
           lw_source      TYPE abaptxt255,                                   " ABAP Text Line with Length 255
           ls_options     TYPE rfc_db_opt,                                   " RFC Table Read: Select Options / WHERE Clause
           ls_fields      TYPE rfc_db_fld,                                   " RFC Table Read: Description of Fields to Retrieve
