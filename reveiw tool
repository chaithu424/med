*----------------------------------------------------------------------*
  FORM sub_determine_role  CHANGING p_g_role_indc TYPE z_review_role. " Role for review process

    READ TABLE t_review_role ASSIGNING FIELD-SYMBOL(<l_review_role>)
                                WITH KEY user_id = sy-uname
                                BINARY SEARCH.
    IF sy-subrc <> 0.
      MESSAGE i999 WITH 'You are not authorized to this transaction.' 'Please reach to admin'.
      LEAVE LIST-PROCESSING.
    ENDIF. " IF sy-subrc <> 0

*  1) Check if any record found with active status for any under going review for the same ECR.
*  2) If found and reviewer id is empty then check the user is admin or not if admin then give ADMIN ROLE.
*  3) If found then Check the user name with reviewer ID if matches then give the REVIEWER ROLE.
*  4) If the user name matches with the developer id then give the DEVELOPER ROLE.
*  5) If entry not found then give the DEVELOPER ROLE

    READ TABLE t_review_hd ASSIGNING FIELD-SYMBOL(<l_review_hd>)
                           WITH KEY counter = w_review_hd_act-counter.

    IF sy-subrc = 0.

*     If the status is Approved then the report will be shown in display mode irrespective of role
      IF w_review_hd_act-status = '3'. " Approved
        p_g_role_indc = c_role_o.
        RETURN.
      ENDIF. " IF sy-subrc = 0

      IF <l_review_hd>-reviewer_id IS INITIAL.

        READ TABLE t_review_role ASSIGNING <l_review_role>
                                WITH KEY user_id = sy-uname
                                         role = c_role_a
                                BINARY SEARCH.
        IF sy-subrc = 0.

          p_g_role_indc = c_role_a.

        ELSE. " ELSE -> IF sy-subrc = 0
          MESSAGE s999 WITH 'One open review request exists.' 'Object is not assigned to any Reviewer yet'.
          LEAVE LIST-PROCESSING.
        ENDIF. " IF sy-subrc = 0

      ENDIF. " IF <l_review_hd>-reviewer_id IS INITIAL


      IF <l_review_hd>-reviewer_id = sy-uname.
        p_g_role_indc = c_role_r.

      ELSEIF <l_review_hd>-developer_id = sy-uname.
        p_g_role_indc = c_role_d.

      ELSE. " ELSE -> IF <l_review_hd>-reviewer_id = sy-uname
        READ TABLE t_review_role ASSIGNING <l_review_role>
                                WITH KEY user_id = sy-uname
                                         role = c_role_a
                                BINARY SEARCH.
        IF sy-subrc = 0.
          p_g_role_indc = c_role_a.

        ENDIF. " IF sy-subrc = 0
      ENDIF. " IF <l_review_hd>-reviewer_id = sy-uname

*     If not role is set then we will give the user the DISPLAY ONLY access
      IF p_g_role_indc IS INITIAL.
        IF <l_review_hd>-reviewer_id IS NOT INITIAL
          AND <l_review_hd>-admin_id IS NOT INITIAL.

          p_g_role_indc = c_role_o.
        ENDIF. " IF <l_review_hd>-reviewer_id IS NOT INITIAL
      ENDIF. " IF p_g_role_indc IS INITIAL

    ELSE. " ELSE -> IF <l_review_hd>-reviewer_id IS NOT INITIAL

      READ TABLE t_review_role ASSIGNING <l_review_role>
                              WITH KEY user_id = sy-uname
                                       role = c_role_d
                              BINARY SEARCH.
      IF sy-subrc = 0.

        p_g_role_indc = c_role_d.

      ENDIF. " IF sy-subrc = 0

    ENDIF. " IF sy-subrc = 0

    IF p_g_role_indc = c_role_d AND
      w_review_hd_act-status = '1'.

      MESSAGE i999 WITH 'One open review request exists.' 'Review is pending with Admin.' 'Please reach to them.'.
      LEAVE LIST-PROCESSING.
    ENDIF. " IF p_g_role_indc = c_role_d AND

  ENDFORM.
