                            shtyp      = ls_shipment-shtyp
                            tplst      = ls_shipment-tplst
                            message    = TEXT-002 ) TO gt_shipments_time.

          ELSE.
            APPEND VALUE #( tknum      = ls_shipment-tknum
                            shtyp      = ls_shipment-shtyp
                            tplst      = ls_shipment-tplst
                            status_old = gv_time_evt_frm
                            status_new = gv_time_evt_to
                            message    = TEXT-003 ) TO gt_shipments_time.
            COMMIT WORK.

          ENDIF.
        ENDIF.            "++ADD:ATTIRH2:20-May-2025:ECR254365533:INC12358248
      ELSE.
*        APPEND VALUE #( tknum      = ls_shipment-tknum
*                       shtyp      = ls_shipment-shtyp
*                       tplst      = ls_shipment-tplst
*                       message    = |{ TEXT-004 } { gv_time_evt_frm }| ) TO gt_shipments_time.
      ENDIF.
      CLEAR: ls_time_data.
    ENDLOOP.

