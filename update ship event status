      TRY.
          DATA(ls_tseg_hist) = gt_tseg_hist[  tknum = ls_shipment-tknum ].
          IF ls_tseg_hist-value_new IS NOT INITIAL.
            CONTINUE.
          ENDIF.
        CATCH cx_sy_itab_line_not_found.
      ENDTRY.
* End ADD:ATTIRH2:18-AUG-2025:DEFECT31597
      get_events( ls_shipment ).
      READ TABLE gt_time_data INTO DATA(ls_time_data) WITH KEY head_hdl = ls_shipment-handle
                                                               even = gv_time_evt_frm
                                                               BINARY SEARCH.
      IF ( sy-subrc = 0 AND ls_time_data-even_tstfr IS NOT INITIAL ) OR ( gv_time_evt_frm = gc_constants-zmdt_10 AND gv_time_evt_to = gc_constants-zmdt_11 ).
