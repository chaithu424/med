        READ TABLE gt_time_data INTO DATA(ls_time_to) WITH KEY head_hdl = ls_shipment-handle
                                                              even = gv_time_evt_to
                                                              BINARY SEARCH.
        IF sy-subrc = 0 AND ls_time_to-even_tstfr IS INITIAL.
*     End ADD:ATTIRH2:20-May-2025:ECR254365533:INC12358248
          update_time_events( EXPORTING iv_event = gv_time_evt_to is_vttk = ls_shipment
                              IMPORTING ev_error = DATA(lv_error) ).
          IF  lv_error = abap_true.
