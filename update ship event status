  METHOD constructor.

    CONSTANTS:
      BEGIN OF lc_enhancements,
        rdd1902              TYPE z_orf_enhancement VALUE 'RDD1902',
        shipment_status_from TYPE z_orf_enhancement_attr VALUE 'SHIPMENT_STATUS_FROM',
        shipment_status_to   TYPE z_orf_enhancement_attr VALUE 'SHIPMENT_STATUS_TO',
        shipment_status      TYPE z_orf_char_name VALUE 'STTRG',
      END OF lc_enhancements.


    SELECT enhancement_attr, char_value
          FROM zorf_enhancement
          INTO TABLE @DATA(lt_enhancements)
         WHERE enhancement EQ @lc_enhancements-rdd1902 AND
               inactive    EQ @abap_false.
    IF syst-subrc EQ 0.
      LOOP AT lt_enhancements REFERENCE INTO DATA(lr_enhancement).

        CASE lr_enhancement->enhancement_attr.
          WHEN lc_enhancements-shipment_status_from.
            APPEND VALUE #( key = lr_enhancement->char_value ) TO gt_status_from.

          WHEN lc_enhancements-shipment_status_to.
            APPEND VALUE #( key = lr_enhancement->char_value ) TO gt_status_to.
        ENDCASE.

      ENDLOOP.
    ENDIF.

  ENDMETHOD.


  METHOD initialization.

    et_status_from = gt_status_from.
    et_status_to   = gt_status_to.

  ENDMETHOD.
*  Begin ADD:ATTIRH2:16-Apr-2025:ECR254365533:DEFECT31319
  METHOD get_time_events.
    DATA: lt_from  TYPE vrm_values,
          lt_to    TYPE vrm_values,
          lv_index TYPE i VALUE 9.

    SELECT even, even_ali FROM ttsegevty INTO TABLE @DATA(lt_events_time)
      WHERE even LIKE @gc_constants-mdt_events.
    IF  sy-subrc = 0.
      lt_from = VALUE #( FOR ls_time_events IN lt_events_time WHERE ( even <> gc_constants-zmdt_19 )
                                           ( key = ls_time_events-even
                                            text = ls_time_events-even_ali ) ).
      lt_to = VALUE #( FOR ls_time_events IN lt_events_time WHERE ( even <> gc_constants-zmdt_10 )
                                           ( key = ls_time_events-even
                                          text = ls_time_events-even_ali ) ).
      et_time_from = lt_from.
      et_time_to  = lt_to.
    ENDIF.
  ENDMETHOD.
* End ADD:ATTIRH2:16-Apr-2025:ECR254365533:DEFECT31319

  METHOD select_data.

    TYPES:
      BEGIN OF ts_preceding_doc,
        vbeln TYPE vbeln,
      END OF ts_preceding_doc.

    DATA:
      lt_preceding_docs TYPE STANDARD TABLE OF ts_preceding_doc.

    DATA: lt_deliveries TYPE RANGE OF vbeln.
*---Remember selection:
    gs_selection = is_selection.
* Begin ADD:ATTIRH2:16-Apr-2025:ECR254365533:DEFECT31319
    IF gs_selection-update_time = abap_true.
      gv_time_evt_frm = gs_selection-time_from.
      gv_time_evt_to = gs_selection-time_to.
      gv_time_checked = abap_true.
      gs_selection-status_from = 1.     "++ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
    ENDIF.
*    End ADD:ATTIRH2:16-Apr-2025:ECR254365533:DEFECT31319
*---Get possible shipments/deliveries:
    SELECT vttk~tknum, vttk~shtyp, vttk~tplst, vttk~sttrg,
           vttp~tpnum, vttp~vbeln
          FROM (            vttk
                 INNER JOIN vttp
                         ON vttp~tknum EQ vttk~tknum
               ) INTO TABLE @DATA(lt_shipment_deliveries)
         WHERE vttk~tknum IN @gs_selection-r_tknum AND   "++ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
               vttk~tplst IN @gs_selection-r_tplst AND
               vttk~shtyp IN @gs_selection-r_shtyp AND
               vttk~dalbg IN @gs_selection-r_dalbg AND
               vttk~route IN @gs_selection-r_route AND
               vttk~vsbed IN @gs_selection-r_vsbed AND
               vttk~sttrg EQ @gs_selection-status_from AND
               vttk~tndrst IN @gs_selection-r_tndrst.   "++ADD:ATTIRH2:18-AUG-2025:DEFECT31597

    IF syst-subrc NE 0 OR
       lt_shipment_deliveries IS INITIAL.
*-----No shipments found:
      RETURN.
    ELSE.
*-----Just keep 1 delivery per shipment:
      SORT lt_shipment_deliveries BY tknum.
      DELETE ADJACENT DUPLICATES FROM lt_shipment_deliveries COMPARING tknum. "#EC CI_SEL_DEL
    ENDIF.


*---Check preceding documents if needed:
    IF gs_selection-r_kunwe IS NOT INITIAL OR
       gs_selection-r_land1 IS NOT INITIAL OR
       gs_selection-r_vkorg IS NOT INITIAL OR
       gs_selection-r_vtweg IS NOT INITIAL OR
       gs_selection-r_vstel IS NOT INITIAL.

*-----Select delivery information:
      SELECT lips~vbeln, lips~posnr, lips~vgbel
            FROM (            likp
                   INNER JOIN kna1
                           ON kna1~kunnr EQ likp~kunnr
                   INNER JOIN lips
                           ON lips~vbeln EQ likp~vbeln
                 ) INTO TABLE @DATA(lt_delivery_info)
             FOR ALL ENTRIES IN @lt_shipment_deliveries
           WHERE likp~vbeln EQ @lt_shipment_deliveries-vbeln AND
                 likp~kunnr IN @gs_selection-r_kunwe         AND
                 likp~vstel IN @gs_selection-r_vstel         AND
                 kna1~land1 IN @gs_selection-r_land1.
      IF syst-subrc EQ 0.
        SORT lt_delivery_info BY vbeln.

        IF gs_selection-r_vkorg IS NOT INITIAL OR
           gs_selection-r_vtweg IS NOT INITIAL.
*---------Collect preceding documents:
          lt_preceding_docs = CORRESPONDING #( lt_delivery_info MAPPING vbeln = vgbel ).

          IF lt_preceding_docs IS NOT INITIAL.

            SORT lt_preceding_docs BY vbeln.
            DELETE ADJACENT DUPLICATES FROM lt_preceding_docs.

            SELECT vbeln
                  FROM vbak
                  INTO TABLE @DATA(lt_sales_orders)
                   FOR ALL ENTRIES IN @lt_preceding_docs
                 WHERE vbeln EQ @lt_preceding_docs-vbeln AND
                       vkorg IN @gs_selection-r_vkorg    AND
                       vtweg IN @gs_selection-r_vtweg.
            IF syst-subrc EQ 0.
              SORT lt_sales_orders BY vbeln.
            ENDIF.

            SELECT ebeln
                  FROM ekpv
                  INTO TABLE @DATA(lt_stos)
                   FOR ALL ENTRIES IN @lt_preceding_docs
                 WHERE ebeln EQ @lt_preceding_docs-vbeln AND
                       vkorg IN @gs_selection-r_vkorg    AND
                       vtweg IN @gs_selection-r_vtweg.
            IF syst-subrc EQ 0.
              SORT lt_stos BY ebeln.
            ENDIF.
*- Begin ADD:TEDLAN2:05-Nov-2024:INC11624332
            " Deliveries fetching based on Deliveries and Distribution channel
            IF lt_delivery_info IS NOT INITIAL.
              SELECT vbeln, vtweg
                     FROM lips
                     INTO TABLE @DATA(lt_lips)
                     FOR ALL ENTRIES IN @lt_delivery_info
                     WHERE vbeln = @lt_delivery_info-vbeln AND
                           vtweg IN @gs_selection-r_vtweg.
              IF sy-subrc IS NOT INITIAL.
                SORT lt_lips BY vbeln.
              ENDIF.

            ENDIF.
*- End ADD:TEDLAN2:05-Nov-2024:INC11624332

*-----------Check deliveries based on preceding documents:
            LOOP AT lt_delivery_info REFERENCE INTO DATA(lr_delivery_info).

              READ TABLE lt_sales_orders TRANSPORTING NO FIELDS
                  WITH KEY vbeln = lr_delivery_info->vgbel BINARY SEARCH.
              IF syst-subrc NE 0.
                READ TABLE lt_stos TRANSPORTING NO FIELDS
                    WITH KEY ebeln = lr_delivery_info->vgbel BINARY SEARCH.
                IF syst-subrc NE 0.
*- Begin ADD:TEDLAN2:05-Nov-2024:INC11624332
                  " Deliveries not found based on selection Distribution channel then not consider record
                  READ TABLE lt_lips TRANSPORTING NO FIELDS
                     WITH KEY vbeln = lr_delivery_info->vbeln BINARY SEARCH.
                  IF sy-subrc IS NOT INITIAL.
*- End ADD:TEDLAN2:05-Nov-2024:INC11624332
                    CLEAR:
                      lr_delivery_info->vbeln.
                  ENDIF.          "++ ADD:TEDLAN2:05-Nov-2024:INC11624332
                ENDIF.
              ENDIF.

            ENDLOOP.

            DELETE lt_delivery_info WHERE vbeln EQ space. "#EC CI_SEL_DEL  "#EC CI_STDSEQ

          ENDIF.

        ENDIF.

      ENDIF.
* Begin ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
      IF gv_time_checked = abap_true.
        CLEAR gs_selection-status_from.
        lt_deliveries = VALUE #( FOR ls_del IN lt_delivery_info ( sign = 'I' option = 'EQ' low = ls_del-vbeln ) ).
        CHECK lt_deliveries IS NOT INITIAL.
        DELETE lt_shipment_deliveries WHERE vbeln NOT IN lt_deliveries.
        SELECT * FROM vttk
        INTO TABLE @gt_ship_handle
        FOR ALL ENTRIES IN @lt_shipment_deliveries
        WHERE tknum = @lt_shipment_deliveries-tknum.
        IF  sy-subrc = 0.
          SELECT head_hdl, even, even_tstfr FROM tsege
            INTO TABLE @gt_time_data
            FOR ALL ENTRIES IN @gt_ship_handle
              WHERE head_hdl = @gt_ship_handle-handle
*              AND even IN (  @gs_selection-time_from, @gs_selection-time_to )  "++ADD:ATTIRH2:20-May-2025:ECR254365533:INC12358248
              AND even_verty = @gc_constants-actual_time.
          IF  sy-subrc = 0.
            SORT gt_time_data BY head_hdl even.                               "++ADD:ATTIRH2:20-May-2025:ECR254365533:INC12358248
          ENDIF.
* Begin ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
*  Standard functionality doesn't store entries in TSEGE unless any changes on the Further dates screen
*  in VT02N or updates to Time segment events

          LOOP AT gt_ship_handle INTO DATA(ls_ship_handle).
            " If no entries exist in gt_time_data for the current handle
            IF NOT line_exists( gt_time_data[ head_hdl = ls_ship_handle-handle ] ).
              gt_time_data = VALUE #( BASE gt_time_data
                   head_hdl = ls_ship_handle-handle
                (  even = gc_constants-zmdt_10 )
                (  even = gc_constants-zmdt_11 )
                (  even = gc_constants-zmdt_12 )
                (  even = gc_constants-zmdt_13 )
                (  even = gc_constants-zmdt_14 )
                (  even = gc_constants-zmdt_15 )
                (  even = gc_constants-zmdt_16 )
                (  even = gc_constants-zmdt_17 )
                (  even = gc_constants-zmdt_18 )
                (  even = gc_constants-zmdt_19 ) ).
            ENDIF.

            CLEAR ls_ship_handle.
          ENDLOOP.
          SORT gt_time_data BY head_hdl even.
* End ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
        ENDIF.
* Begin ADD:ATTIRH2:18-AUG-2025:DEFECT31597
        IF gt_ship_handle IS NOT INITIAL AND gs_selection-cta = abap_true.
          SELECT tknum, event, udate, utime, fname, value_new
          FROM zorf_tsege_hist
          INTO TABLE @gt_tseg_hist
          FOR ALL ENTRIES IN @gt_ship_handle
          WHERE tknum  = @gt_ship_handle-tknum
          AND   event  = @gc_constants-zmdt_10
          AND fname    = @gc_constants-cta_reason.
          IF sy-subrc = 0.
            SORT gt_tseg_hist BY tknum event fname ASCENDING udate utime DESCENDING.
            DELETE ADJACENT DUPLICATES FROM gt_tseg_hist COMPARING tknum event fname.
          ENDIF.
        ENDIF.
* End ADD:ATTIRH2:18-AUG-2025:DEFECT31597
        EXIT.
      ENDIF.
* End   ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966

*-----Check shipments based on deliveries:
      LOOP AT lt_shipment_deliveries REFERENCE INTO DATA(lr_shipment_delivery).

        READ TABLE lt_delivery_info TRANSPORTING NO FIELDS
            WITH KEY vbeln = lr_shipment_delivery->vbeln BINARY SEARCH.
        IF syst-subrc EQ 0.
          APPEND VALUE #( tknum      = lr_shipment_delivery->tknum
                          shtyp      = lr_shipment_delivery->shtyp
                          tplst      = lr_shipment_delivery->tplst
                          status_old = lr_shipment_delivery->sttrg ) TO gt_shipments.
        ENDIF.

      ENDLOOP.

    ELSE.
      gt_shipments = CORRESPONDING #( lt_shipment_deliveries MAPPING status_old = sttrg ).
    ENDIF.

  ENDMETHOD.


  METHOD  process_shipments.

    CONSTANTS:
      BEGIN OF lc_action,
        add    TYPE bapishipmentchangeaction VALUE 'A',
        delete TYPE bapishipmentchangeaction VALUE 'D',
        change TYPE bapishipmentchangeaction VALUE 'C',
      END   OF lc_action,

      BEGIN OF lc_shipment_status,
        planned             TYPE sttrg VALUE '0',
        planning_completed  TYPE sttrg VALUE '1',
        check_in            TYPE sttrg VALUE '2',
        loading_start       TYPE sttrg VALUE '3',
        loading_end         TYPE sttrg VALUE '4',
        shipment_completion TYPE sttrg VALUE '5',
        shipment_start      TYPE sttrg VALUE '6',
        shipment_end        TYPE sttrg VALUE '7',
      END   OF lc_shipment_status.

    DATA:
      ls_headerdata            TYPE bapishipmentheader,
      ls_action                TYPE bapishipmentheaderaction,
      lt_headerdeadlines       TYPE STANDARD TABLE OF bapishipmentheaderdeadline,
      lt_headerdeadlineactions TYPE STANDARD TABLE OF bapishipmentheaderdeadlineact,
      lt_return                TYPE STANDARD TABLE OF bapiret2,
      lv_user                  TYPE syst-uname.    "++HEUTMJ2:12-FEB-2024:RITM3672963


*---Process each shipment:
    LOOP AT gt_shipments REFERENCE INTO DATA(lr_shipment).

*-----Try to lock shipment, if not successful set message to use and continue with next shipment:
      CALL FUNCTION 'ENQUEUE_EVVTTKE'
        EXPORTING
          tknum          = lr_shipment->tknum
        EXCEPTIONS
          foreign_lock   = 1
          system_failure = 2.
      IF syst-subrc NE 0.
        WRITE syst-msgv1 TO lv_user.                                                  "++HEUTMJ2:12-FEB-2024:RITM3672963
        MESSAGE e011(vw) WITH lr_shipment->tknum lv_user INTO lr_shipment->message.   "++HEUTMJ2:12-FEB-2024:RITM3672963
        CONTINUE.
      ENDIF.


*-----Initialize:
      CLEAR:
        ls_action,
        ls_headerdata,
        lt_return.


*-----Set header data:
      ls_headerdata-shipment_num = lr_shipment->tknum.

      CASE gs_selection-status_to.
        WHEN lc_shipment_status-planned.
          ls_headerdata-status_plan = abap_true.
          ls_action-status_plan     = lc_action-change.
        WHEN lc_shipment_status-check_in.
          ls_headerdata-status_checkin = abap_true.
          ls_action-status_checkin     = lc_action-change.
        WHEN lc_shipment_status-loading_start.
          ls_headerdata-status_load_start = abap_true.
          ls_action-status_load_start     = lc_action-change.
        WHEN lc_shipment_status-loading_end.
          ls_headerdata-status_load_end = abap_true.
          ls_action-status_load_end     = lc_action-change.
        WHEN lc_shipment_status-shipment_completion.
          ls_headerdata-status_compl = abap_true.
          ls_action-status_compl     = lc_action-change.
        WHEN lc_shipment_status-shipment_start.
          ls_headerdata-status_shpmnt_start = abap_true.
          ls_action-status_shpmnt_start     = lc_action-change.
        WHEN lc_shipment_status-shipment_end.
          ls_headerdata-status_shpmnt_end = abap_true.
          ls_action-status_shpmnt_end     = lc_action-change.
      ENDCASE.


*---Call BAPI:
      CALL FUNCTION 'BAPI_SHIPMENT_CHANGE'
        EXPORTING
          headerdata       = ls_headerdata
          headerdataaction = ls_action
        TABLES
          return           = lt_return.

      TRY.
          lr_shipment->message = lt_return[ type = 'E' ]-message. "#EC CI_STDSEQ

          CALL FUNCTION 'BAPI_TRANSACTION_ROLLBACK'.

        CATCH cx_sy_itab_line_not_found.
*-------No error found: commit
          CALL FUNCTION 'BAPI_TRANSACTION_COMMIT'.

          lr_shipment->status_new = gs_selection-status_to.
      ENDTRY.

    ENDLOOP.

  ENDMETHOD.


  METHOD display.

*---Instantiate the ALV:
    TRY.
        CALL METHOD cl_salv_table=>factory
          IMPORTING
            r_salv_table = go_alv
          CHANGING
            t_table      = ct_table.

      CATCH cx_salv_msg .
        RETURN.
    ENDTRY.


*---Set columns:
    TRY.
        go_alv->get_columns( )->set_optimize( ).

        LOOP AT go_alv->get_columns( )->get( ) REFERENCE INTO DATA(lr_column).

          CASE lr_column->columnname.
            WHEN gc_columns-status_old.
              lr_column->r_column->set_short_text( CONV scrtext_s( TEXT-s01 ) ).
              lr_column->r_column->set_medium_text( CONV scrtext_m( TEXT-m01 ) ).
              lr_column->r_column->set_long_text( CONV scrtext_l( TEXT-l01 ) ).

            WHEN gc_columns-status_new.
              lr_column->r_column->set_short_text( CONV scrtext_s( TEXT-s02 ) ).
              lr_column->r_column->set_medium_text( CONV scrtext_m( TEXT-m02 ) ).
              lr_column->r_column->set_long_text( CONV scrtext_l( TEXT-l02 ) ).

            WHEN gc_columns-message.
              lr_column->r_column->set_short_text( CONV scrtext_s( TEXT-s03 ) ).
              lr_column->r_column->set_medium_text( CONV scrtext_m( TEXT-m03 ) ).
              lr_column->r_column->set_long_text( CONV scrtext_l( TEXT-l03 ) ).
          ENDCASE.

        ENDLOOP.

      CATCH cx_salv_not_found.                          "#EC NO_HANDLER
    ENDTRY.


*---Display the result:
    go_alv->display( ).

  ENDMETHOD.

