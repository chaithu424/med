*  Check the time for the events which is greater than Time from and without blank time
    DATA(lt_time_gt_from)  = gt_time_data.
    DELETE lt_time_gt_from WHERE even LE gv_time_evt_frm.
    DELETE lt_time_gt_from WHERE even_tstfr IS INITIAL.
*  End ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
*    Begin ADD:ATTIRH2:16-Apr-2025:ECR254365533:DEFECT31319
    LOOP AT gt_ship_handle INTO DATA(ls_shipment).
*  Begin ADD:ATTIRH2:29-May-2025:ECR254365533:INC12386966
*  If time is updated for any of the
      IF line_exists( lt_time_gt_from[ head_hdl = ls_shipment-handle ] ).
